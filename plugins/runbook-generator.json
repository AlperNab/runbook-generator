      "required": false,
      "options": [
        "Draft",
        "Production",
        "Audit / strict review",
        "JSON/API output"
      ],
      "default": "Production",
      "help": "Controls strictness, depth, and output format for this project workflow.",
      "affects": [
        "workflow",
        "validation",
        "export"
