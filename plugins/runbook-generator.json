{
  "slug": "runbook-generator",
  "name": "Runbook Generator",
  "domain": "DevOps / SRE",
  "target_user": "Domain operator, business owner, analyst, or team member who needs this workflow executed reliably.",
  "core_job": "Service architecture → operational runbook",
  "deep_features": [
    "incident decision trees",
    "SLO/SLA sections",
    "rollback plan",
    "escalation matrix",
    "health checks",
    "postmortem template",
    "on-call checklist"
  ],
  "input_schema": [
    {
      "key": "service_architecture",
      "label": "Service architecture",
      "type": "text",
      "required": true,
      "help": "Affects input: Service architecture.",
      "affects": [
        "prompt",
        "workflow"
      ],
      "default": ""
    },
    {
      "key": "work_brief",
      "label": "Work brief / source text / URL / instructions",
      "type": "textarea",
      "required": true,
      "default": "",
      "help": "Paste the material, URL, description, or instruction needed for this project.",
      "affects": [
        "prompt",
        "workflow"
      ]
    }
  ],
  "customization_schema": [
